# 火山方舟 API Key（用于翻译）
# 兼容说明：也支持使用 OPENAI_API_KEY 变量名，但推荐统一改为 ARK_API_KEY
ARK_API_KEY=your-ark-api-key-here

# ElevenLabs API Key（用于语音合成）
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ElevenLabs Voice ID（默认：Rachel，免费额度可用）
# 更多 Voice ID 参见：https://elevenlabs.io/docs/api-reference/get-voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# 数据库地址（Docker 运行时会被 docker-compose 覆盖）
# DATABASE_URL=sqlite:///./translator.db

# ------------------------------
# 飞书多维表格批量同步配置
# ------------------------------
# 飞书应用凭证（用于换取 tenant_access_token）
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 多维表格定位（App Token + Table ID）
FEISHU_BITABLE_APP_TOKEN=bascnxxxxxxxxxxxx
FEISHU_TABLE_ID=tblxxxxxxxxxxxx

# 字段映射（按你的表头名）
FEISHU_CHINESE_FIELD=中文脚本
FEISHU_ENGLISH_FIELD=英文脚本
FEISHU_AUDIO_FIELD=音频

# 自动轮询
FEISHU_POLL_ENABLED=false
FEISHU_POLL_INTERVAL_SECONDS=60
FEISHU_BATCH_SIZE=20

# 同步时的默认翻译模式和可选音色
FEISHU_TRANSLATE_MODE=short_video
# FEISHU_VOICE_ID=

# 降级模式：音频失败时仍回填英文脚本
FEISHU_FALLBACK_TEXT_ONLY_ON_AUDIO_FAIL=true
