# OpenAI API Key（用于翻译）
OPENAI_API_KEY=sk-your-openai-api-key-here

# ElevenLabs API Key（用于语音合成）
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# ElevenLabs Voice ID（默认：Rachel，免费额度可用）
# 更多 Voice ID 参见：https://elevenlabs.io/docs/api-reference/get-voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# 数据库地址（Docker 运行时会被 docker-compose 覆盖）
# DATABASE_URL=sqlite:///./translator.db
